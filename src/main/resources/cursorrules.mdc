## 8. 전체 예시

### {pageName}.js

```javascript
const campaignHandler = (() => {

    // 1. STATE
    const state = {
        currentPage: 1,
        totalPage: 0,
        list: [],
        searchParams: {
            keyword: '',
            status: '',
        },
    };

    // 2. SET STATE
    function setState(newState) {
        Object.assign(state, newState);
    }

    // 3. RENDER
    const render = {
        list() {
            const tbody = document.getElementById('campaignList');
            if (!state.list.length) {
                tbody.innerHTML = `<tr><td colspan="5" class="empty-row">캠페인이 없습니다.</td></tr>`;
                return;
            }
            tbody.innerHTML = state.list.map(item => `
                <tr>
                    <td>${item.campaignId}</td>
                    <td>${item.campaignName}</td>
                    <td>${item.status}</td>
                    <td>
                        <button class="btn-sm" onclick="campaignHandler.handler.onDelete('${item.campaignId}')">삭제</button>
                    </td>
                </tr>
            `).join('');
        },
        paging() {
            pagingHandler.render('pagingContainer', state.currentPage, state.totalPage, (page) => {
                fetch.list(page);
            });
        }
    };

    // 4. FETCH
    const fetch = {
        list(page = 1) {
            apiHandler.fetchApiGet(
                '/console/v1/api/alimtalk/campaign',
                { ...state.searchParams, page },
                (data) => {
                    setState({ list: data.list, currentPage: page, totalPage: data.totalPage });
                    render.list();
                    render.paging();
                },
                (message) => alertHandler.showWarnAlert(message)
            );
        }
    };

    // 5. HANDLER
    const handler = {
        onSearch() {
            const keyword = document.getElementById('keyword').value.trim();
            const status  = document.getElementById('status').value;
            setState({ searchParams: { keyword, status } });
            fetch.list(1);
        },
        onReset() {
            setState({ searchParams: { keyword: '', status: '' } });
            document.getElementById('searchForm').reset();
            fetch.list(1);
        },
        onDelete(campaignId) {
            if (!confirm('캠페인을 삭제하시겠습니까?')) return;
            apiHandler.fetchApiDelete(
                `/console/v1/api/alimtalk/campaign/${campaignId}`,
                null,
                () => {
                    alertHandler.showInfoAlert('삭제되었습니다.');
                    fetch.list(state.currentPage);
                },
                (message) => alertHandler.showWarnAlert(message)
            );
        }
    };

    // 6. INIT
    function init() {
        fetch.list(1);
    }

    return { handler };

})();
```

### {pageName}.html (버튼 부분)

```html
<!-- 검색 영역 -->
<input type="text" id="keyword" placeholder="캠페인명 검색"
       onkeypress="if(event.key==='Enter') campaignHandler.handler.onSearch()">
<select id="status">
    <option value="">전체</option>
    <option value="ACTIVE">활성</option>
    <option value="INACTIVE">비활성</option>
</select>
<button onclick="campaignHandler.handler.onSearch()">검색</button>
<button onclick="campaignHandler.handler.onReset()">초기화</button>

<!-- 목록 -->
<table>
    <tbody id="campaignList"></tbody>
</table>

<!-- 페이징 -->
<div id="pagingContainer"></div>
```
